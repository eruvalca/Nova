@using Cropper.Blazor.Components
@using Microsoft.AspNetCore.Components.Forms

<div class="profile-photo-editor">
    @if (_errorMessages.Count > 0)
    {
        <div class="alert alert-danger" role="alert">
            <ul class="mb-0 list-unstyled">
                @foreach (var error in _errorMessages)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    @if (ImageDataUrl is null)
    {
        @if (ExistingPhotoUrl is not null)
        {
            <div class="mb-3 text-center">
                <img src="@ExistingPhotoUrl" alt="Your current profile photo" class="profile-photo-current rounded-circle" />
                <p class="text-muted mt-2">Your current profile photo. Choose a new image to replace it.</p>
            </div>
        }

        <div class="mb-3">
            <label for="profile-photo-input" class="form-label">Choose a photo</label>
            <InputFile id="profile-photo-input" class="form-control" accept="@AcceptTypes" OnChange="OnFileSelectedAsync"
                       disabled="@IsBusy" />
            <div class="form-text">JPEG, PNG, or WebP. Maximum size 10 MB.</div>
        </div>
        @if (!string.IsNullOrEmpty(CancelUrl))
        {
            <button type="button" class="btn btn-outline-secondary" @onclick="CancelPhoto" disabled="@IsBusy">
                Cancel
            </button>
        }
    }
    else
    {
        <div class="profile-photo-cropper-frame">
            <NovaCropperComponent @ref="_cropper" Class="profile-photo-cropper" Src="@ImageDataUrl"
                                  Options="_cropperOptions" />
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="button" class="btn btn-primary" @onclick="SavePhotoAsync" disabled="@IsBusy">
                @if (IsBusy)
                {
                    <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                }
                Save photo
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="ChooseDifferentPhoto" disabled="@IsBusy">
                Choose a different photo
            </button>
            @if (!string.IsNullOrEmpty(CancelUrl))
            {
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelPhoto" disabled="@IsBusy">
                    Cancel
                </button>
            }
        </div>
    }
</div>
