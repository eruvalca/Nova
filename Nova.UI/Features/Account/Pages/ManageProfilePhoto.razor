@page "/Account/Manage/ProfilePhoto"
@rendermode InteractiveAuto
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Nova.UI.Features.Account.Components

<PageTitle>Profile photo</PageTitle>

<div class="row">
    <div class="col-lg-8">
        <h1>Profile photo</h1>
        <p>
            Update your profile photo. Choose a new image and crop it to your liking —
            it will be shown as a circular avatar.
        </p>
        <ProfilePhotoEditor ReturnUrl="/Account/Manage" CancelUrl="/Account/Manage" />
    </div>
</div>
