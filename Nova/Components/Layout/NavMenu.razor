@using Nova.Shared.Security

<nav class="navbar navbar-expand-md navbar-light bg-light border-top fixed-bottom">
    <div class="container-fluid">
        <NavLink class="navbar-brand" href="" Match="NavLinkMatch.All">Nova</NavLink>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main-nav-menu"
                aria-controls="main-nav-menu" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="main-nav-menu">
            <ul class="navbar-nav me-auto mb-2 mb-md-0">
                <AuthorizeView>
                    <Authorized>
                        @if (ClubDetailUrl is not null && ClubName is not null)
                        {
                            <li class="nav-item">
                                <NavLink class="nav-link" href="@ClubDetailUrl" Match="NavLinkMatch.Prefix">@ClubName
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="players" Match="NavLinkMatch.Prefix">Players</NavLink>
                            </li>
                        }
                    </Authorized>
                </AuthorizeView>
            </ul>
            <ul class="navbar-nav ms-auto mb-2 mb-md-0">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-2" href="Account/Manage">
                                @if (context.User.HasClaim(c => c.Type == NovaClaimTypes.HasProfilePhoto))
                                {
                                    <img class="nav-avatar" src="@PhotoUrl" alt="Profile photo" />
                                }
                                Manage
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <form action="Account/Logout" method="post" class="d-inline">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="@CurrentUrl" />
                                <button type="submit" class="btn nav-link border-0">Logout</button>
                            </form>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="Account/Login">Login</NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>
